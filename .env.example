# VBC Explorer Environment Variables
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ===========================================
# Required Configuration
# ===========================================

# MongoDB Connection URI
# Format: mongodb://user:password@host:port/database?authSource=authDB
MONGODB_URI=mongodb://explorer:your_secure_password@localhost:27017/explorerDB?authSource=explorerDB

# ===========================================
# Optional Configuration
# ===========================================

# Web3 Provider URL (overrides config.json)
# WEB3_PROVIDER_URL=http://localhost:8545

# Node Environment
NODE_ENV=development

# ===========================================
# API Keys (Optional)
# ===========================================

# CoinGecko API Key (for higher rate limits)
# COINGECKO_API_KEY=your_api_key

# ===========================================
# Security Settings (Production)
# ===========================================

# Session Secret (for future auth features)
# SESSION_SECRET=your_random_secret_here

# ===========================================
# Deployment Settings
# ===========================================

# Port (Next.js default is 3000)
# PORT=3000

# Base URL for production
# NEXT_PUBLIC_BASE_URL=https://explorer.example.com
