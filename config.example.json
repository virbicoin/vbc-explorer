{
  "nodeAddr": "localhost",
  "port": 8545,
  "wsPort": 8546,
  "bulkSize": 100,
  "syncAll": true,
  "quiet": false,
  "useRichList": true,
  "startBlock": 0,
  "endBlock": null,
  "maxRetries": 3,
  "retryDelay": 1000,
  "logLevel": "info",
  "enableNFT": true,
  "enableContractVerification": true,
  "enableTokenTracking": true,
  "apiRateLimit": 100,
  "webSocketEnabled": true,
  "web3Provider": {
    "url": "http://localhost:8545"
  },
  "currency": {
    "name": "Ethereum",
    "symbol": "ETH",
    "unit": "wei",
    "decimals": 18,
    "gasUnit": "Gwei",
    "priceApi": {
      "_comment": "Price APIs are tried in order: CoinGecko → CMC → Coinpaprika → WikaEx → DEX",
      "coingecko": {
        "enabled": true,
        "id": "ethereum",
        "_comment": "CoinGecko coin ID (see https://www.coingecko.com/en/api/documentation)"
      },
      "cmc": {
        "enabled": false,
        "id": "ethereum",
        "_comment": "Requires CMC_API_KEY environment variable. ID is the CMC slug."
      },
      "coinpaprika": {
        "enabled": true,
        "id": "eth-ethereum",
        "_comment": "Coinpaprika coin ID (see https://api.coinpaprika.com/v1/coins)"
      },
      "wikaex": {
        "enabled": false,
        "symbol": "ETH",
        "_comment": "WikaEx trading symbol (CoinGecko-compatible API at https://wikaex.com/api/spot/coingecko/tickers)"
      },
      "dex": {
        "enabled": true,
        "pairAddress": "0x0000000000000000000000000000000000000000",
        "stablecoinAddress": "0x0000000000000000000000000000000000000000",
        "stablecoinDecimals": 6,
        "_comment": "DEX fallback: pairAddress is the LP pair with stablecoin, used when external APIs fail"
      }
    },
    "_comment": "For custom networks: name/symbol/unit/gasUnit can be customized (e.g., VirBiCoin/VBC/niku/Gniku)"
  },
  "performance": {
    "memoryLimitMB": 512,
    "nodeOptions": "--max-old-space-size=512"
  },
  "caching": {
    "enabled": true,
    "duration": 300
  },
  "miners": {
    "0x0000000000000000000000000000000000000001": "Example Pool 1",
    "0x0000000000000000000000000000000000000002": "Example Pool 2"
  },
  "features": {
    "nft": {
      "enabled": true,
      "metadataProviders": ["ipfs", "http"],
      "imageFallback": true,
      "cacheEnabled": true
    },
    "contractVerification": {
      "enabled": true,
      "compilerVersions": [
        "0.8.30",
        "0.8.29",
        "0.8.28",
        "0.8.27",
        "0.8.26",
        "0.8.25",
        "0.8.24",
        "0.8.23",
        "0.8.22",
        "0.8.21",
        "0.8.20",
        "0.8.19",
        "0.8.18",
        "0.8.17",
        "0.8.16",
        "0.8.15",
        "0.8.14",
        "0.8.13",
        "0.8.12",
        "0.8.11",
        "0.8.10"
      ],
      "optimizationEnabled": true,
      "maxSourceSize": 50000
    },
    "richlist": {
      "enabled": true,
      "updateInterval": 3600,
      "minBalance": "1000000000000000000"
    },
    "statistics": {
      "enabled": true,
      "updateInterval": 300,
      "blockRange": 100
    }
  },
  "api": {
    "rateLimit": {
      "windowMs": 900000,
      "max": 100
    },
    "cors": {
      "origin": ["https://explorer.example.com", "http://localhost:3000"],
      "credentials": true
    }
  },
  "database": {
    "uri": "${MONGODB_URI}",
    "options": {
      "maxPoolSize": 50,
      "serverSelectionTimeoutMS": 15000,
      "socketTimeoutMS": 60000,
      "connectTimeoutMS": 15000,
      "bufferCommands": false,
      "autoIndex": false,
      "autoCreate": false
    },
    "_comment": "Use environment variable MONGODB_URI for security. Example: mongodb://user:password@localhost:27017/explorerDB?authSource=explorerDB"
  },
  "logging": {
    "level": "info",
    "file": {
      "enabled": true,
      "maxSize": "10m",
      "maxFiles": 5
    },
    "console": {
      "enabled": true,
      "colorize": true
    }
  },
  "explorer": {
    "name": "Blockchain Explorer",
    "description": "Real-time blockchain explorer for EVM-compatible networks",
    "version": "0.7.6",
    "url": "https://explorer.example.com",
    "apiUrl": "https://explorer.example.com/api",
    "copyright": "Your Company Name",
    "github": "https://github.com/virbicoin/vbc-explorer",
    "legacyUrls": []
  },
  "network": {
    "chainId": 1,
    "name": "Ethereum Mainnet",
    "slug": "ethereum",
    "rpcUrl": "http://localhost:8545",
    "wsUrl": "ws://localhost:8546",
    "explorer": "https://explorer.example.com",
    "blockTime": 12,
    "_comment": "slug is used for URL-friendly identifiers (e.g., virbicoin for VirBiCoin network)"
  },
  "dex": {
    "enabled": false,
    "factory": "0x0000000000000000000000000000000000000000",
    "router": "0x0000000000000000000000000000000000000000",
    "masterChef": "0x0000000000000000000000000000000000000000",
    "wrappedNative": {
      "address": "0x0000000000000000000000000000000000000000",
      "name": "Wrapped Native Token",
      "symbol": "WETH",
      "decimals": 18
    },
    "rewardToken": {
      "address": "0x0000000000000000000000000000000000000000",
      "symbol": "REWARD",
      "name": "Reward Token",
      "decimals": 18
    },
    "tokens": {
      "usdt": {
        "address": "0x0000000000000000000000000000000000000000",
        "name": "Tether USD",
        "symbol": "USDT",
        "decimals": 6
      },
      "usdc": {
        "address": "0x0000000000000000000000000000000000000000",
        "name": "USD Coin",
        "symbol": "USDC",
        "decimals": 6
      }
    },
    "lpTokens": {
      "usdtWeth": {
        "address": "0x0000000000000000000000000000000000000000",
        "name": "USDT-WETH LP",
        "symbol": "USDT-ETH LP",
        "token0": "USDT",
        "token1": "WETH"
      }
    },
    "farmPools": [
      {
        "pid": 0,
        "name": "Example LP Pool",
        "lpToken": "0x0000000000000000000000000000000000000000",
        "token0Symbol": "USDT",
        "token1Symbol": "ETH"
      }
    ],
    "_comment": "Set enabled: true and configure contract addresses to enable DEX features"
  },
  "bridge": {
    "enabled": false,
    "relayEtaSeconds": 90,
    "routes": [
      {
        "id": "native-bsc",
        "label": "TOKEN → wTOKEN (BNB Smart Chain)",
        "asset": { "kind": "native", "symbol": "TOKEN", "decimals": 18 },
        "vault": "0x0000000000000000000000000000000000000000",
        "remote": {
          "chainId": 56,
          "name": "BNB Smart Chain",
          "nativeSymbol": "BNB",
          "rpcUrl": "https://bsc-dataseed.binance.org",
          "explorer": "https://bscscan.com",
          "bridge": "0x0000000000000000000000000000000000000000",
          "wrappedToken": "0x0000000000000000000000000000000000000000",
          "wrappedSymbol": "wTOKEN",
          "dexName": "PancakeSwap",
          "swapUrl": "https://pancakeswap.finance/swap?outputCurrency=0x0000000000000000000000000000000000000000"
        }
      }
    ],
    "_comment": "Cross-chain lock-and-mint bridge. 'routes' is a list, so more assets/destinations can be added over time. Per route: 'asset' is what leaves this chain (kind 'native', or 'erc20' with a 'token' address and 'decimals'); it is locked in 'vault' and minted as 'wrappedToken' on the remote chain. Optional 'dexName'/'swapUrl' link the wrapped token to an external DEX. The legacy single 'vault'+'remote' shape (without 'routes') is still supported."
  },
  "launchpad": {
    "enabled": true,
    "factoryAddress": "0x0000000000000000000000000000000000000000",
    "legacyFactories": [
      {
        "address": "0x0000000000000000000000000000000000000000",
        "version": "v1",
        "note": "Previous factory contract (optional, for showing tokens from old contracts)"
      }
    ],
    "creationFee": "10000000000000000000",
    "alternativePayment": {
      "enabled": false,
      "token": {
        "address": "0x0000000000000000000000000000000000000000",
        "symbol": "ALT",
        "decimals": 18
      },
      "fee": "800000000000000000000",
      "discountLabel": "20% OFF",
      "burnNote": "will be permanently burned",
      "contractFunctions": {
        "getFeeInfo": "getAlternativeFeeInfo",
        "createToken": "createTokenWithAlternative",
        "createTokenWithMetadata": "createTokenWithAlternativeAndMetadata"
      },
      "_comment": "Alternative payment token for token creation (e.g., project governance token). contractFunctions maps generic names to actual contract function names."
    },
    "_comment": "Token Launchpad for no-code token creation. Set factoryAddress to enable."
  },
  "tokenIcons": {
    "ETH": {
      "icon": "/img/eth.svg",
      "color": "from-blue-500 to-purple-600"
    },
    "WETH": {
      "icon": "/img/eth.svg",
      "color": "from-blue-400 to-purple-500"
    },
    "USDT": {
      "icon": "/img/USDT.svg",
      "color": "from-green-400 to-emerald-500"
    },
    "USDC": {
      "icon": "/img/USDC.svg",
      "color": "from-blue-400 to-blue-500"
    },
    "_comment": "Token icons and gradient colors for UI display. Keys are token symbols."
  },
  "blacklist": {
    "symbols": ["TEST", "FIX", "FIX2"],
    "tokens": [
      {
        "address": "0x0000000000000000000000000000000000000000",
        "name": "Example Blacklisted Token",
        "symbol": "SPAM",
        "reason": "Example reason for blacklisting"
      }
    ],
    "launchpadTokens": [
      {
        "address": "0x0000000000000000000000000000000000000000",
        "symbol": "TEST",
        "reason": "Test token, fully burned or deprecated"
      }
    ],
    "lpPairs": [
      {
        "address": "0x0000000000000000000000000000000000000000",
        "name": "Example/SPAM LP",
        "reason": "Contains blacklisted token"
      }
    ],
    "_comment": "Blacklisted tokens/pairs will be hidden from DEX, Launchpad, and token lists"
  },
  "social": {
    "x": "https://x.com/your_project",
    "twitter": "https://x.com/your_project",
    "discord": "https://discord.gg/your_invite",
    "telegram": "https://t.me/your_channel",
    "github": "https://github.com/your-repo",
    "_comment": "Social media links displayed in footer and pages"
  },
  "dexInfo": {
    "name": "Your DEX Name",
    "description": "Decentralized exchange description",
    "logo": "https://example.com/logo.png",
    "url": "https://explorer.example.com/dex",
    "analyticsUrl": "https://explorer.example.com/dex/analytics",
    "docsUrl": "https://explorer.example.com/dex/docs",
    "stablePoolAddress": "0x0000000000000000000000000000000000000000",
    "stablePoolName": "USDT-WETH LP",
    "swapFee": "0.3%",
    "protocolFee": "0.05%",
    "lpReward": "0.25%",
    "_comment": "DEX metadata for GeckoTerminal/CoinGecko listing applications"
  },
  "supply": {
    "blockReward": 2,
    "premineAmount": 0,
    "excludedAddresses": [
      {
        "address": "0x0000000000000000000000000000000000000000",
        "label": "Burn Address"
      },
      {
        "address": "0x0000000000000000000000000000000000000001",
        "label": "Treasury Contract"
      }
    ],
    "cacheDuration": 60,
    "_comment": "Supply calculation for /api/total_supply and /api/circulating_supply endpoints (CoinGecko/CMC compatible)"
  },
  "knownTokens": {
    "0x...tokenAddress1": {
      "name": "Token Name",
      "symbol": "TKN",
      "decimals": 18,
      "type": "VRC-20"
    },
    "0x...tokenAddress2": {
      "name": "NFT Collection",
      "symbol": "NFT",
      "decimals": 0,
      "type": "VRC-721"
    }
  }
}
