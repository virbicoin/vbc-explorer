{
  "apps": [
    {
      "name": "explorer",
      "script": "npm",
      "args": "start",
      "cwd": ".",
      "env": {
        "NODE_ENV": "production",
        "NODE_OPTIONS": "--max-old-space-size=512",
        "MEMORY_LIMIT_MB": "512"
      },
      "max_memory_restart": "1024M",
      "instances": 1,
      "exec_mode": "fork",
      "autorestart": true,
      "watch": false,
      "max_restarts": 10,
      "min_uptime": "30s",
      "restart_delay": 10000,
      "log_file": "./logs/web.log",
      "out_file": "./logs/web-out.log",
      "error_file": "./logs/web-error.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    },
    {
      "name": "sync",
      "script": "npx",
      "args": "ts-node --project tsconfig.tools.json tools/sync.ts sync",
      "cwd": ".",
      "wait_ready": true,
      "listen_timeout": 10000,
      "env": {
        "NODE_ENV": "production",
        "NODE_OPTIONS": "--max-old-space-size=1200",
        "MEMORY_LIMIT_MB": "1024"
      },
      "max_memory_restart": "1200M",
      "instances": 1,
      "exec_mode": "fork",
      "autorestart": true,
      "watch": false,
      "max_restarts": 30,
      "min_uptime": "60s",
      "restart_delay": 60000,
      "log_file": "./logs/sync.log",
      "out_file": "./logs/sync-out.log",
      "error_file": "./logs/sync-error.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    },
