# ============================================
# VBC Explorer - Production Environment
# ============================================
# Copy this file to .env.production and fill in your values
# This file is for PRODUCTION deployments only
#
# SECURITY WARNING:
# - NEVER commit .env.production to version control
# - Use strong, unique passwords
# - Rotate credentials regularly
# - Consider using secret management (Vault, AWS Secrets, etc.)
# ============================================

# ============================================
# REQUIRED - Database Configuration
# ============================================

# MongoDB Connection URI (Production)
# Use a replica set for high availability:
# mongodb://user:pass@host1:27017,host2:27017,host3:27017/db?replicaSet=rs0&authSource=authDB
MONGODB_URI=mongodb://explorer:CHANGE_THIS_PASSWORD@localhost:27017/explorerDB?authSource=explorerDB

# ============================================
# REQUIRED - Blockchain Node Configuration
# ============================================

# Web3 RPC Provider URL (Production)
# Use a load balancer or multiple nodes for redundancy
WEB3_PROVIDER_URL=https://rpc.your-network.com

# WebSocket Provider URL (Production)
WS_URL=wss://rpc.your-network.com

# Public RPC URL
RPC_URL=https://rpc.your-network.com

# ============================================
# REQUIRED - Server Configuration
# ============================================

# Node Environment (must be 'production')
NODE_ENV=production

# Base URL for the explorer
NEXT_PUBLIC_BASE_URL=https://explorer.your-network.com

# Server Port
PORT=3000

# ============================================
# RECOMMENDED - API Keys
# ============================================

# CoinGecko API Key (Pro plan recommended for production)
COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx

# ============================================
# REQUIRED - Security Settings
# ============================================

# Session Secret (CHANGE THIS!)
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_HEX_STRING

# API Rate Limit (requests per 15 minutes per IP)
API_RATE_LIMIT=100

# ============================================
# OPTIONAL - Logging
# ============================================

# Log Level (production should use 'warn' or 'error')
LOG_LEVEL=warn

# ============================================
# OPTIONAL - Performance
# ============================================

# Node.js Memory Limit (MB)
# NODE_OPTIONS=--max-old-space-size=512

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# [ ] Changed MONGODB_URI password
# [ ] Set correct RPC/WS URLs for your network
# [ ] Set NEXT_PUBLIC_BASE_URL to your domain
# [ ] Generated unique SESSION_SECRET
# [ ] Set up SSL/TLS certificates
# [ ] Configured reverse proxy (nginx/caddy)
# [ ] Set up monitoring and alerting
# [ ] Configured backup strategy for MongoDB
# [ ] Tested all API endpoints
# [ ] Verified CORS settings in config.json
