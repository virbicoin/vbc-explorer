#!/usr/bin/env sh
# Pre-commit hook: run the fast CI checks before committing.
# Enabled via the package.json "prepare" script, which sets
# `git config core.hooksPath .githooks`.

# A repo-local core.hooksPath overrides the user's global hooks, so chain
# the global pre-commit first (e.g. a GPG passphrase cache warmer).
global_hooks=$(git config --global core.hooksPath 2>/dev/null)
if [ -n "$global_hooks" ] && [ -x "$global_hooks/pre-commit" ]; then
  "$global_hooks/pre-commit" || exit 1
fi

echo "> pre-commit: running 'npm run check'..."
if ! npm run check; then
  echo ""
  echo "x Checks failed; commit aborted."
  echo "  Most issues can be auto-fixed with 'npm run format' and 'npm run lint:fix'."
  exit 1
fi
echo "+ pre-commit: checks passed."
